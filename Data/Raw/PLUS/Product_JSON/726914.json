{"versionInfo": {"hasModuleVersionChanged": false, "hasApiVersionChanged": false}, "data": {"ProductOut": {"Overview": {"Name": "Arla Skyr naturel yoghurt 0% vet", "Subtitle": "Per Beker 450 g  (per kilo \u20ac4.42)", "Brand": "Arla", "Slug": "arla-skyr-naturel-yoghurt-0-vet-beker-450-g-726914", "Image": {"Label": "Arla Skyr naturel yoghurt 0% vet 450 Gram", "URL": "https://images.ctfassets.net/s0lodsnpsezb/726914_M/614b2ebea97f1e63a58da3a50bff59f9/726914.png"}, "Meta": {"Description": "Bestel Arla Skyr naturel yoghurt 0% vet 450 Gram online op plus.nl. Laat je boodschappen makkelijk en snel thuis bezorgen of haal het op bij jouw PLUS.", "Title": "Arla Skyr naturel yoghurt 0% vet 450 Gram - PLUS"}, "IsNIX18": false, "Price": "1.99", "BaseUnitPrice": "4.42", "LineItem": {"Id": "0", "Quantity": 0}, "IsOfflineSaleOnly": false, "IsServiceItem": false, "IsAvailableInStore": true, "MaxOrderLimit": 199, "IsNoIndex": false, "IsLocalItem": false}, "ProductClassificationId": "Standaard", "Categories": {"List": [{"Name": "Zuivel, eieren, boter"}, {"Name": "Verse zuivel"}, {"Name": "Yoghurt"}, {"Name": "Paasassortiment"}, {"Name": "Paasontbijt"}, {"Name": "Paasontbijt eieren, melk, yoghurt"}]}, "Logos": {"PDPInUpperLeft": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPInProductInformation": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPBehindSizeUnit": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPBelowAddToCart": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPAboveTitle": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPInRemarks": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}}, "Legal": {"RegulatedName": "Magere yoghurt", "HealthClaim": "Arla Skyr is van nature rijk aan eiwitten, bevat 0% vet en is heerlijk romigvan smaak, geschikt voor elke topping", "DrainWeight": {"UoM": "", "Value": 0}, "RequiredNotificationByLaw": "", "AppointedAuthority": "", "AdittionalClassification": {"System": "", "Trades": ""}}, "UsageDuring": {"BreastFeeding": "", "Pregnancy": "", "SafePeriodAfterOpening": 0}, "Marketing": {"Description": "", "UniqueSellingPoint": "Arla Skyr Naturel Yoghurt 0% vet 450g\nSkyr is van nature rijk aan eiwit (10 gram eiwit per 100 gram)\nArla Skyr yoghurt bevat geen kunstmatige geur-, kleur-, en smaakstoffen\nIJslandse yoghurt met een zijdezachte dikke textuur die romig van smaak is\nWat je ochtend ook brengt, Arla Skyr brengt je verder", "Message": "Arla Skyr Naturel is een heerlijke yoghurt in IJslandse stijl. Skyr is van nature rijk aan eiwit, bevat 0% vet en is toch lekker romig van smaak. Haal meer uit je ochtend met Arla Skyr.\nIn IJsland ontbijten ze al sinds 1000 jaar eiwitrijk met Skyr, yoghurt gemaakt volgens een 1000 jaar oud recept. Arla Skyr bevat van nature 10 gram eiwit per 100 gram. Dat is 2,7 keer meer dan gewone yoghurt en bijna 1,3 keer meer dan kwark. Ook heeft de yoghurt een heerlijke zijdezachte, maar dikke textuur. De romige naturel smaak zorgt dat je er meer van kan genieten. Dit zou de reden kunnen zijn dat IJslanders iedere dag optimistisch starten, klaar voor iedere mogelijke uitdaging die op je pad komt. Probeer de heerlijk romige naturel yoghurt van Arla Skyr ook eens met vers fruit, noten of granola. Wat je ochtend ook brengt, naturel yoghurt van Arla Skyr brengt je verder.\nBij Arla geloven we dat elke keuze een verschil maakt. We werken elke dag aan het verbeteren van onze verpakkingen en het verminderen van voedselverspilling. Zo zijn de Arla Skyr bekers nu gemaakt van 100% gerecycled plastic* en hebben we de plastic deksel verwijderd. Hiermee vermijden we het gebruik van nieuw en overbodig plastic. Niet zeker of de Arla Skyr uit de koelkast nog goed is? Met de toevoeging van het label 'ten minste houdbaar tot' moedigen we je aan om te kijken, ruiken en proeven. Onze producten zijn vaak nog goed na de houdbaarheidsdatum. Help mee recyclen door de verpakking te scheiden. Als de Arla Skyr op is, scheid je de papieren wikkel en de plastic folie van de beker. Alles moet apart worden weggegooid voor de beste recyclebare resultaten. De verbeteringen die we maken lijken klein, maar gezamenlijk kunnen deze individuele verbeteringen het verschil maken voor ons allemaal. Meer weten? Check Arla.nl/skyr. *Beker is zonder papieren wikkel (gemaakt van 80 % gerecycled karton) en zonder dekselfolie (gemaakt van PET-plastic)."}, "SupplierContact": {"LegalContact": {"Address": "Antwoordnummer 46, 3860 VB\u00a0 Nijkerk", "Name": "Arla Foods Consumentenservice"}, "LegalSupplier": {"Address": "", "Name": ""}, "PDP_ProductMeans": {"Email_List": {"List": [], "EmptyListItem": ""}, "SocialMedia_List": {"List": [], "EmptyListItem": ""}, "Contact_List": {"List": ["0800-2352752"]}, "WebSites_List": {"List": ["arla.nl"]}}}, "Composition": "", "Ingredients": "Ingredi\u00ebnten: Magere YOGHURT", "Nutrient": {"Base": {"UoM": "gram", "Value": 100}, "Additional": {"NutricionalClaim": "", "PreparedDeviation": "Deze waarden gelden voor het niet bereide product", "ReferenceIntake": ""}, "Nutrients": {"List": [{"TypeCode": "", "UnitCode": "", "Description": "Energie KJ", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "255.0", "UoM": "kilojoule"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Energie KC", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "60.0", "UoM": "KC"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Vet", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "0.0", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Waarvan verzadigd vet", "ParentCode": "FAT", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "0.0", "UoM": "gram