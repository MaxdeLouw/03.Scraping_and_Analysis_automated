HealthClaim": "High protein. Low sugar.", "DrainWeight": {"UoM": "", "Value": 0}, "RequiredNotificationByLaw": "", "AppointedAuthority": "", "AdittionalClassification": {"System": "", "Trades": ""}}, "UsageDuring": {"BreastFeeding": "", "Pregnancy": "", "SafePeriodAfterOpening": 0}, "Marketing": {"Description": "", "UniqueSellingPoint": "\u00cdsey Skyr Air Cherry - Chocolate is een luchtige prote\u00efnerijke mousse volgens traditioneel IJslands recept gemaakt van kersen skyr met \u00e9chte stukjes chocolade.\nHoog in prote\u00efnen, laag in vet en suiker\nLactosevrij, glutenvrij en Nutri-Score A\nBevat halal gecertificeerde gelatine", "Message": "Ideaal als tussendoortje, voor of na het sporten en als toetje\n\u00cdsey Skyr is een uniek zuivelproduct uit IJsland. Heerlijke eetzuivel waarbij de originele skyr al 1100 jaar volgens IJslandse traditie van moeder op dochter werd doorgegeven. \u00cdsey Skyr wordt met moderne technologie geproduceerd, maar nog steeds volgens traditioneel recept. Het product heeft een uniek bereidingsproces, waarbij er 3,5 zoveel melk wordt gebruikt als bij gewone yoghurt of kwark en de originele IJslandse skyr-culturen worden toegevoegd. Door op het einde van de bereiding het vocht uit de skyr te halen, krijg je een romige textuur zonder dat de prote\u00efnen verloren gaan! De producten van \u00cdsey Skyr zijn verkrijgbaar in verschillende varianten en geschikt voor ieder moment van de dag."}, "SupplierContact": {"LegalContact": {"Address": "Postbus 8052\n1180 LB Amstelveen, Nederland", "Name": "Skyr Nederland B.V."}, "LegalSupplier": {"Address": "", "Name": ""}, "PDP_ProductMeans": {"Email_List": {"List": [], "EmptyListItem": ""}, "SocialMedia_List": {"List": [], "EmptyListItem": ""}, "Contact_List": {"List": [], "EmptyListItem": ""}, "WebSites_List": {"List": ["iseyskyr.com"]}}}, "Composition": "", "Ingredients": "Ingredi\u00ebnten: gepasteuriseerde magere MELK (DK), water, kersen (8%), ROOM (4%), chocolade (1,1%) (cacaoboter, cacaopoeder, magere cacaopoeder, BOTERCONCENTRAAT, suiker), gelatine (halal), gemodificeerd ma\u00efszetmeel, emulgator (mono- en diglyceridenvan vetzuren veresterd met melkzuur), fruit-/groenteconcentraat, verdikkingsmiddel (pectine), aroma, zoetstoffen (sucralose, acesulfaam K), lactase, skyr-culturen, schuimmiddel (stikstof).", "Nutrient": {"Base": {"UoM": "gram", "Value": 100}, "Additional": {"NutricionalClaim": "", "PreparedDeviation": "Deze waarden gelden voor het niet bereide product", "ReferenceIntake": ""}, "Nutrients": {"List": [{"TypeCode": "", "UnitCode": "", "Description": "Energie KJ", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "343.0", "UoM": "kilojoule"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Energie KC", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "82.0", "UoM": "KC"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Vet", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "3.1", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Waarvan verzadigd vet", "ParentCode": "FAT", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "2.1", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Koolhydraten", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "4.7", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Waarvan suikers", "ParentCode": "CHOAVL", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "4.3", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Eiwitten", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "8.7", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Zout", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "0.14", "UoM": "gram"}, "SortO