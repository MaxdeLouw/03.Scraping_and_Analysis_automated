nRemarks": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}}, "Legal": {"RegulatedName": "Skyr Framboos-Granaatappel. Bevat zoetstoffen", "HealthClaim": "High protein. No added sugar. Low fat. Dit product bevat van nature aanwezige suikers", "DrainWeight": {"UoM": "", "Value": 0}, "RequiredNotificationByLaw": "", "AppointedAuthority": "", "AdittionalClassification": {"System": "", "Trades": ""}}, "UsageDuring": {"BreastFeeding": "", "Pregnancy": "", "SafePeriodAfterOpening": 0}, "Marketing": {"Description": "", "UniqueSellingPoint": "\u00cdsey Skyr Framboos - Granaatappel is prote\u00efnerijke skyr volgens traditioneel IJslands recept in een handig knijpzakje.\nHoog in prote\u00efnen, laag in suiker en vetarm\nLactosevrij, glutenvrij en Nutri-Score A\nIdeaal voor ontbijt, tussendoortje en voor of na het sporten", "Message": "\u00cdsey Skyr is een uniek zuivelproduct uit IJsland. Heerlijke eetzuivel waarbij de originele skyr al 1100 jaar volgens IJslandse traditie van moeder op dochter werd doorgegeven. \u00cdsey Skyr wordt met moderne technologie geproduceerd, maar nog steeds volgens traditioneel recept. Het product heeft een uniek bereidingsproces, waarbij er 3,5 zoveel melk wordt gebruikt als bij gewone yoghurt of kwark en de originele IJslandse skyr-culturen worden toegevoegd. Door op het einde van de bereiding het vocht uit de skyr te halen, krijg je een romige textuur zonder dat de prote\u00efnen verloren gaan! De producten van \u00cdsey Skyr zijn verkrijgbaar in verschillende varianten en geschikt voor ieder moment van de dag."}, "SupplierContact": {"LegalContact": {"Address": "Postbus 8052 \n1180 LB Amstelveen, Nederland", "Name": "Skyr Nederland B.V."}, "LegalSupplier": {"Address": "", "Name": ""}, "PDP_ProductMeans": {"Email_List": {"List": [], "EmptyListItem": ""}, "SocialMedia_List": {"List": [], "EmptyListItem": ""}, "Contact_List": {"List": [], "EmptyListItem": ""}, "WebSites_List": {"List": ["www.iseyskyr.com"]}