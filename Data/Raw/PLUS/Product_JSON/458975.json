{"versionInfo": {"hasModuleVersionChanged": false, "hasApiVersionChanged": false}, "data": {"ProductOut": {"Overview": {"Name": "Arla Bio skyr naturel yoghurt", "Subtitle": "Per Beker 450 g  (per kilo \u20ac5.76)", "Brand": "Arla", "Slug": "arla-bio-skyr-naturel-yoghurt-beker-450-g-458975", "Image": {"Label": "Arla Bio skyr naturel yoghurt 450 Gram", "URL": "https://images.ctfassets.net/s0lodsnpsezb/458975_M/e142e55f7333b71027f6b3c61e8b044c/458975.png"}, "Meta": {"Description": "Bestel Arla Bio skyr naturel yoghurt 450 Gram online op plus.nl. Laat je boodschappen makkelijk en snel thuis bezorgen of haal het op bij jouw PLUS.", "Title": "Arla Bio skyr naturel yoghurt 450 Gram - PLUS"}, "IsNIX18": false, "Price": "2.59", "BaseUnitPrice": "5.76", "LineItem": {"Id": "0", "Quantity": 0}, "IsOfflineSaleOnly": false, "IsServiceItem": false, "IsAvailableInStore": true, "MaxOrderLimit": 199, "IsNoIndex": false, "IsLocalItem": false}, "ProductClassificationId": "Standaard", "Categories": {"List": [{"Name": "Zuivel, eieren, boter"}, {"Name": "Verse zuivel"}, {"Name": "Yoghurt"}]}, "Logos": {"PDPInUpperLeft": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPInProductInformation": {"List": [{"Name": "EU Organic Farming", "LongDescription": "Biologisch", "URL": "https://images.ctfassets.net/s0lodsnpsezb/L_RVVfT1JHQU5JQ19GQVJNSU5H_M/317926d861f3e545c6411bc00fd66dd4/L_RVVfT1JHQU5JQ19GQVJNSU5H.png", "Order": 0}]}, "PDPBehindSizeUnit": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPBelowAddToCart": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPAboveTitle": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}, "PDPInRemarks": {"List": [], "EmptyListItem": {"Name": "", "LongDescription": "", "URL": "", "Order": 0}}}, "Legal": {"RegulatedName": "Lactosevrije* biologische magere yoghurt *Lactosegehalte <lt/>0,01 g/100 g", "HealthClaim": "Van nature rijk aan eiwit\n0% vet", "DrainWeight": {"UoM": "", "Value": 0}, "RequiredNotificationByLaw": "", "AppointedAuthority": "", "AdittionalClassification": {"System": "", "Trades": ""}}, "UsageDuring": {"BreastFeeding": "", "Pregnancy": "", "SafePeriodAfterOpening": 0}, "Marketing": {"Description": "", "UniqueSellingPoint": "Arla Bio skyr naturel 450 g\nArla gebruikt groene stroom voor minder impact op het klimaat\nDierenwelzijn staat centraal, de koeien lopen bij goed weer lekker buiten\nVoor een gezondere bodem gebruiken biologische boeren geen kunstmest\nArla Bio skyr is rijk aan eiwit, bevat 0% vet en is lekker romig van smaak", "Message": "Skyr van Arla Bio, kies voor lekker puur!\nArla Bio skyr is van nature rijk aan eiwit. Lekker voor bij jouw ontbijt. Probeer de skyr van Arla Bio ook eens met granola en vers fruit of gewoon als toevoeging bij je smoothie. \n\nDe biologische boeren van Arla zetten zich in voor de natuur van vandaag en morgen. Weten hoe? Lees snel verder! Voor minder impact op het klimaat gebruiken we groene stroom op de boerderij en in de fabriek. Samen met partner Trees for All legt Arla Bio op en rondom Nederlandse boerderijen boslandbouw aan (een duurzame vorm van landbouw waarbij bomen/struiken worden gecombineerd met akkerbouw/veeteelt op hetzelfde stuk land). Ze leggen ten minste 15 hectare grond boslandbouw aan van 2026 t/m 2028. Dit is vergelijkbaar met 22 voetbalvelden! Deze aanpak draagt bij aan het beter vasthouden van water in de bodem en ondersteunt de biodiversiteit. Dierenwelzijn staat centraal, de koeien lopen minimaal 150 dagen per jaar en 6 uur per dag lekker buiten, als het weer het toelaat. Voor een gezondere bodem gebruiken biologische boeren geen kunstmest. Wist je dat een gezonde bodem CO2 kan opslaan? Weten wat ze nog meer doen? Check Arla.nl/Biologisch"}, "SupplierContact": {"LegalContact": {"Address": "Antwoordnummer 46, 3860 VB  Nijkerk, Nederland", "Name": "Arla Foods Consumentenservice"}, "LegalSupplier": {"Address": "", "Name": ""}, "PDP_ProductMeans": {"Email_List": {"List": [], "EmptyListItem": ""}, "SocialMedia_List": {"List": [], "EmptyListItem": ""}, "Contact_List": {"List": [], "EmptyListItem": ""}, "WebSites_List": {"List": ["www.arla.nl"]}}}, "Composition": "", "Ingredients": "Ingredi\u00ebnten: Biologische magere YOGHURT, lactase", "Nutrient": {"Base": {"UoM": "gram", "Value": 100}, "Additional": {"NutricionalClaim": "", "PreparedDeviation": "Deze waarden gelden voor het niet bereide product", "ReferenceIntake": ""}, "Nutrients": {"List": [{"TypeCode": "", "UnitCode": "", "Description": "Energie KJ", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "269.0", "UoM": "kilojoule"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Energie KC", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "63.0", "UoM": "KC"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Vet", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "0.0", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Waarvan verzadigd vet", "ParentCode": "FAT", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "0.0", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Koolhydraten", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "4.0", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Waarvan suikers", "ParentCode": "CHOAVL", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "4.0", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Eiwitten", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityContained": {"Value": "11.0", "UoM": "gram"}, "SortOrder": 0}, {"TypeCode": "", "UnitCode": "", "Description": "Zout", "ParentCode": "", "DailyValueIntakePercent": "", "QuantityConta